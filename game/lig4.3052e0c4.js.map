        gameObjectsList.forEach((gameObject)=>{
            gameObject.update({
                gameCanvas: gameCanvas
            });
        });
    }
    render({ gameCanvas: gameCanvas, gameObjectsList: gameObjectsList }) {
        this.clean({
            gameCanvas: gameCanvas
        });
        this.update({
            gameCanvas: gameCanvas,
            gameObjectsList: gameObjectsList
        });
        gameObjectsList.forEach((gameObject)=>{
            gameObject.render({
                gameCanvas: gameCanvas
            });
        });
        window.requestAnimationFrame(()=>{
            this.render({
                gameCanvas: gameCanvas,
                gameObjectsList: gameObjectsList
            });
        });
    }
}


